# --- SMTP pentru formularele site-ului ---
# Pentru Gmail folosește un App Password (NU parola contului):
#   https://myaccount.google.com/apppasswords
# Necesită ca 2-Step Verification să fie activat pe cont.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

SMTP_USER=masajgomoldova@gmail.com
SMTP_PASSWORD=app_password_de_16_caractere_fara_spatii

# Opțional: numele care apare în "From" (default: SMTP_USER)
SMTP_FROM="MasajGO <masajgomoldova@gmail.com>"

# Opțional: adresa la care vin notificările (default: siteConfig.email)
SMTP_TO=masajgomoldova@gmail.com
